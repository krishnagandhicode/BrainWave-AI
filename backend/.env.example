PORT=3000
CLIENT_URL=http://localhost:5173
MONGO=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
IMAGE_KIT_ENDPOINT=https://ik.imagekit.io/<your_imagekit_id>
IMAGE_KIT_PUBLIC_KEY=public_<your_imagekit_public_key>
IMAGE_KIT_PRIVATE_KEY=private_<your_imagekit_private_key>
CLERK_SECRET_KEY=sk_test_<your_clerk_secret_key>
GEMINI_API_KEY=<your_gemini_api_key>
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Optional fallback list (comma-separated):
# GEMINI_MODELS=gemini-3.1-flash-lite-preview,gemini-2.5-flash-lite,gemini-2.5-flash
# Optional emergency behavior while quota is exhausted:
# ALLOW_QUOTA_FALLBACK=true
